{
  "version": 3,
  "name": "Krakend API Gateway",
  "port": 8080,
  "timeout": "3000ms",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "endpoints": [
    {
      "endpoint": "/api/users/{path}",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/{path}",
          "encoding": "json",
          "sd": "static",
          "method": "GET",
          "host": [
            "http://user-service.microservices.svc.cluster.local:80"
          ],
          "disable_host_sanitize": false
        }
      ]
    },
    {
      "endpoint": "/api/orders/{path}",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/{path}",
          "encoding": "json",
          "sd": "static",
          "method": "GET",
          "host": [
            "http://order-service.microservices.svc.cluster.local:80"
          ],
          "disable_host_sanitize": false
        }
      ]
    },
    {
      "endpoint": "/api/payments/{path}",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/{path}",
          "encoding": "json",
          "sd": "static",
          "method": "GET",
          "host": [
            "http://payment-service.microservices.svc.cluster.local:80"
          ],
          "disable_host_sanitize": false
        }
      ]
    },
    {
      "endpoint": "/api/notifications/{path}",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/{path}",
          "encoding": "json",
          "sd": "static",
          "method": "GET",
          "host": [
            "http://notification-service.microservices.svc.cluster.local:80"
          ],
          "disable_host_sanitize": false
        }
      ]
    }
  ]
}
