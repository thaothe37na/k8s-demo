{
  "permissions": {
    "allow": [
      "Bash(kubectl get *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl describe *)",
      "Bash(./scripts/local-dev-sync.sh)",
      "Bash(kubectl apply *)",
      "Bash(kubectl rollout *)",
      "Bash(curl -s -o /dev/null -w \"Frontend: HTTP %{http_code}\\\\n\" http://localhost:31423/)",
      "Bash(curl -s http://localhost:31423/api/users/ping)",
      "Bash(curl -s http://localhost:31423/api/orders/ping)",
      "Bash(curl -s http://localhost:31423/api/payments/ping)",
      "Bash(curl -s http://localhost:31423/api/notifications/ping)",
      "Bash(curl -s --connect-timeout 3 -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://172.18.255.200/)",
      "Bash(kubectl port-forward *)",
      "Bash(curl -s -o /dev/null -w \"Port-forward Frontend: HTTP %{http_code}\\\\n\" http://localhost:8080/)",
      "Bash(curl -s http://localhost:8080/api/users/ping)",
      "Bash(curl -s http://localhost:8080/api/orders/ping)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:9090/)",
      "Bash(curl -s http://localhost:9090/api/users/ping)",
      "Bash(curl -s http://localhost:9090/api/orders/ping)",
      "Bash(curl -s http://localhost:9090/api/payments/ping)",
      "Bash(curl -s http://localhost:9090/api/notifications/ping)",
      "Bash(curl -sk -o /dev/null -w \"HTTP %{http_code}\\\\n\" https://localhost:9443/)",
      "Bash(curl -sk https://localhost:9443/api/users/ping)",
      "Bash(curl -sk https://localhost:9443/api/orders/ping)",
      "Bash(curl -sk https://localhost:9443/api/payments/ping)",
      "Bash(curl -sk https://localhost:9443/api/notifications/ping)",
      "Bash(curl -s http://localhost:9091/__health)",
      "Bash(curl -s http://localhost:9091/api/users/ping)",
      "Bash(curl -s http://localhost:9091/api/orders/ping)",
      "Bash(kill %1)",
      "Bash(pkill -f \"port-forward\")",
      "Bash(git rev-list *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(gh --version)",
      "Bash(gh auth *)",
      "Bash(kubectl delete *)",
      "Bash(curl -sk -o /dev/null -w '%{http_code}' https://localhost:9443/)",
      "Bash(echo \"Frontend: $\\(curl -sk -o /dev/null -w '%{http_code}' https://localhost:9443/\\)\")",
      "Bash(echo \"User:     $\\(curl -sk https://localhost:9443/api/users/ping\\)\")",
      "Bash(echo \"Order:    $\\(curl -sk https://localhost:9443/api/orders/ping\\)\")",
      "Bash(echo \"Payment:  $\\(curl -sk https://localhost:9443/api/payments/ping\\)\")",
      "Bash(gh api *)",
      "Bash(python3 -c \"import json,sys; data=json.load\\(sys.stdin\\); [print\\(f' {w[\\\\\"name\\\\\"]}: {w[\\\\\"state\\\\\"]}'\\) for w in data.get\\('workflows',[]\\)]\")",
      "Bash(curl -s https://github.com/thaothe37na/k8s-demo/actions)",
      "Bash(gh run *)",
      "Bash(kubectl set *)",
      "Bash(kubectl patch *)",
      "Bash(curl -s http://localhost:9092/health)",
      "Bash(python3 -m json.tool)",
      "Bash(curl -s http://localhost:9092/ping)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',d).get('command',''))\" 2>/dev/null || true); case \"$CMD\" in *grep*|*rg\\ *|*ripgrep*|*find\\ *|*fd\\ *|*ack\\ *|*ag\\ *)   [ -f graphify-out/graph.json ] &&   echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: knowledge graph at graphify-out/. For focused questions, run `graphify query \\\"<question>\\\"` (scoped subgraph, usually much smaller than GRAPH_REPORT.md) instead of grepping raw files. Read GRAPH_REPORT.md only for broad architecture context.\"}}'   || true ;; esac"
          }
        ]
      }
    ]
  }
}
